[project]
requires = [ "nodejs-24" ]
template = "tanstack-start"
version = "0.0.18"
appliedPatches = [ "nextjs/validate@0.0.20" ]

[dev]
build = [ "pnpm", "install", "--frozen-lockfile" ]
run = [ "pnpm", "run", "dev" ]
deps = [ "git" ]
validate = [ "pnpm", "run", "validate" ]

[deploy]
build = [ "pnpm", "run", "build" ]
run = [ "pnpm", "run", "start" ]
deps = [ "git" ]
